# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrios
DB_USER=postgres
DB_PASSWORD=change_me
DB_SSL=false
DB_POOL_MAX=10

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_SECRET=replace_with_another_long_random_secret_min_32_chars

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# AI assistant provider — pick one via AI_PROVIDER, leave the other keys blank
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
